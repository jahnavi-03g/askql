# ─────────────────────────────────────────────────────────────────────────────
# AskQL CDK — Infrastructure Environment Variables
# Set these before running: cdk deploy
# ─────────────────────────────────────────────────────────────────────────────

# Your Google OAuth Client ID (from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com

# After creating the Bedrock Knowledge Base, paste the IDs here and re-deploy
KNOWLEDGE_BASE_ID=PLACEHOLDER
DATA_SOURCE_ID=PLACEHOLDER

# After creating the Bedrock Agent, paste the IDs here and re-deploy
AGENT_ID=PLACEHOLDER
AGENT_ALIAS_ID=TSTALIASID

# AWS region (default: us-east-1 — Bedrock models available here)
CDK_DEFAULT_REGION=us-east-1
