# ─────────────────────────────────────────────────────────────────────────────
# AskQL — Local Development Environment Variables
# Copy this file to .env.local and fill in values from CDK outputs
# Run: cd infra && cdk deploy  then copy the printed outputs below
# ─────────────────────────────────────────────────────────────────────────────

# Cognito — from CDK output "UserPoolId"
NEXT_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito — from CDK output "UserPoolClientId"
NEXT_PUBLIC_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI domain — format: askql-auth.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_DOMAIN=askql-auth.auth.us-east-1.amazoncognito.com

# API Gateway URL — from CDK output "ApiUrl"
NEXT_PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Amplify redirect URLs (update after Amplify hosting deploy)
NEXT_PUBLIC_REDIRECT_SIGN_IN=http://localhost:3000/auth/callback
NEXT_PUBLIC_REDIRECT_SIGN_OUT=http://localhost:3000
